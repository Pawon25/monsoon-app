# Copy this file to .env and fill in real values. Never commit the real .env file.

# Anthropic Claude API key (server-side only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# OpenWeatherMap API key (free tier): https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-netlify-site.netlify.app

# Caching / polling
WEATHER_CACHE_TTL_SECONDS=300
ALERT_POLL_INTERVAL_SECONDS=900

# Rate limiting
RATE_LIMIT_PER_MINUTE=20
